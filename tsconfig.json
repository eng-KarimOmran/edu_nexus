{
  "compilerOptions": {
    "target": "ES2023",
    "module": "CommonJS",

    "moduleResolution": "node16",
    
    "rootDir": "./src",
    "outDir": "./dist",

    "paths": {
      "@/*": [
        "./src/*"
      ]
    },

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "prisma/**/*.ts"
  ]
}